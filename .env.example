# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# B2C backend base URL
NEXT_PUBLIC_ADMIN_API=https://takneek-b2c.crik.ai/api/v1

# Original Takneek platform API (kept for reference, currently unused)
NEXT_PUBLIC_TAKNEEK_API=https://takneek.crik.ai/api/v1

# Google OAuth 2.0 Client ID (public — from Google Cloud Console → APIs & Services → Credentials)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google OAuth 2.0 Client Secret (server-side only — never prefix with NEXT_PUBLIC_)
GOOGLE_CLIENT_SECRET=

# OAuth redirect URI — must match exactly what's registered in Google Cloud Console
# For local dev: http://localhost:3000/oauth-callback.html
# For production: https://yourdomain.com/oauth-callback.html
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/oauth-callback.html

# R2 / S3 metadata upload (server-side only; leave blank if not configured)
R2_METADATA_URL=
R2_METADATA_TOKEN=

# Optional FFmpeg.wasm asset overrides (wrapper defaults to /vendor/ffmpeg/ffmpeg.js; core defaults load from unpkg when blank)
NEXT_PUBLIC_FFMPEG_WASM_URL=
NEXT_PUBLIC_FFMPEG_CORE_URL=
NEXT_PUBLIC_FFMPEG_CORE_WASM_URL=
